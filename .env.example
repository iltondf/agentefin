# ─────────────────────────────────────────────────────────────────────────
# Agente Financeiro — variáveis de ambiente (exemplo)
# Copie para `.env` e preencha. No Easypanel, defina pela interface.
# NENHUM segredo deve ser versionado.
# ─────────────────────────────────────────────────────────────────────────

# ── Telegram ──
# Token do BotFather.
TELEGRAM_BOT_TOKEN=
# IDs numéricos autorizados, separados por vírgula. VAZIO = nega todos.
ALLOWED_USER_IDS=
# Limite de mensagens por minuto por usuário.
RATE_LIMIT_PER_MIN=20

# ── API BRGlobal (fonte da verdade) ──
# Base da API de agentes (read-only). Local: http://localhost:3333/api/agent/v1
# Produção/homolog: https://SEU-HOST/api/agent/v1
BRGLOBAL_API_BASE_URL=http://localhost:3333/api/agent/v1
# Chave Bearer do agente (formato bgf_live_* / bgf_test_*). Gere no projeto
# financeiro com: pnpm agente:create-key  (escopos read:financeiro,read:extrato)
BRGLOBAL_API_KEY=
# Robustez do cliente HTTP.
HTTP_TIMEOUT=30
HTTP_RETRIES=2
# (Opcional) conta bancária padrão para /painel (habilita seções caixa/extrato).
DEFAULT_CONTA_BANCARIA_ID=

# ── LLM (OPCIONAL — desligada por padrão; o agente funciona 100% sem LLM) ──
LLM_ENABLED=false
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT=20

# ── Observabilidade ──
LOG_LEVEL=INFO
LOG_PATH=logs/app.log
TZ=America/Sao_Paulo
