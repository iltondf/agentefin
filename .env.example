# ─────────────────────────────────────────────────────────────────────────
# Agente Financeiro — variáveis de ambiente (exemplo)
# Copie para `.env` e preencha. NENHUM segredo deve ser versionado.
# ─────────────────────────────────────────────────────────────────────────

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=            # IDs numéricos separados por vírgula. VAZIO = nega todos.
RATE_LIMIT_PER_MIN=30

# ── API BRGlobal (fonte da verdade) ──
BRGLOBAL_API_BASE_URL=https://lixo.brglobal.com.br/api/agent/v1
# Compatibilidade: chave de LEITURA antiga (usada em GET se READ não definida).
BRGLOBAL_API_KEY=
# Chave de LEITURA (opcional; se definida, tem precedência em GET).
BRGLOBAL_READ_API_KEY=
# Chave de ESCRITA (obrigatória para POST). A read-only NÃO deve ter escopo write.
BRGLOBAL_WRITE_API_KEY=
HTTP_TIMEOUT=32
HTTP_RETRIES=2
DEFAULT_CONTA_BANCARIA_ID=

# ── Escrita (gating) ──
# POST só ocorre se WRITE_ENABLED=true E BRGLOBAL_WRITE_API_KEY presente.
WRITE_ENABLED=false

# ── Rascunhos / dados ──
DRAFTS_ENABLED=true
DATA_DIR=/app/data          # local: data
DEFAULTS_FILE=defaults.yaml

# ── LLM (OPCIONAL — desligada por padrão; o agente funciona 100% sem LLM) ──
LLM_ENABLED=false
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=                  # ex.: deepseek/deepseek-chat
OPENROUTER_API_KEY=         # usado quando LLM_PROVIDER=openrouter
LLM_API_KEY=                # alternativa genérica
LLM_TIMEOUT=20

# ── Observabilidade ──
LOG_LEVEL=INFO
LOG_PATH=logs/app.log
TZ=America/Sao_Paulo
